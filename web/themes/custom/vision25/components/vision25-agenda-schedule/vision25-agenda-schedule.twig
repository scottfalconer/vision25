<section{{ attributes.addClass('safe-frame', 'vision25-page-section', 'vision25-page-section--tight-top') }}>
  <div class="section-container vision25-stack--wide">
    <div class="vision25-filter-group" data-filter-group data-filter-target="[data-session-item]">
      <button class="vision25-filter-button is-active" type="button" data-filter-value="all">{{ 'All Tracks'|t }}</button>
      {% for track in tracks %}
        <button class="vision25-filter-button" type="button" data-filter-value="{{ track.id }}">{{ track.name }}</button>
      {% endfor %}
    </div>

    <div class="vision25-stack--wide">
      {% for slot in slots %}
        <section data-scroll-reveal>
          <p class="vision25-time">{{ slot.slot }}</p>
          <div class="vision25-card-grid">
            {% for session in slot.sessions %}
              <button
                class="vision25-card glass-card-elevated"
                type="button"
                data-dialog-open="#agenda-modal-{{ session.id }}"
                aria-controls="agenda-modal-{{ session.id }}"
                aria-expanded="false"
                aria-haspopup="dialog"
                data-session-item
                data-track="{{ session.track_id }}"
              >
                <span class="vision25-card__row">
                  <span class="vision25-time">{{ session.start }}–{{ session.end }}</span>
                  <span class="pill-tag">{{ session.type }}</span>
                </span>
                <h2 class="heading-card">{{ session.title }}</h2>
                <p class="body-base">{{ session.summary }}</p>
                <span class="vision25-card__chips">
                  <span class="vision25-meta">{{ session.room_name }}</span>
                  <span class="pill-tag">{{ session.track_name }}</span>
                  {% if session.lab_title %}
                    <span class="pill-tag">{{ session.lab_title }}</span>
                  {% endif %}
                </span>
              </button>

              <div
                class="vision25-modal"
                data-dialog
                id="agenda-modal-{{ session.id }}"
                role="dialog"
                aria-modal="true"
                aria-labelledby="agenda-modal-title-{{ session.id }}"
                aria-describedby="agenda-modal-summary-{{ session.id }}"
                hidden
              >
                <div class="vision25-modal__panel glass-card-elevated" tabindex="-1">
                  <p class="vision25-time">{{ session.start }}–{{ session.end }}</p>
                  <h2 class="heading-card" id="agenda-modal-title-{{ session.id }}">{{ session.title }}</h2>
                  <p class="vision25-meta">{{ session.room_name }}</p>
                  <p class="body-large" id="agenda-modal-summary-{{ session.id }}">{{ session.summary }}</p>
                  <div class="vision25-card__chips">
                    <span class="pill-tag">{{ session.track_name }}</span>
                    {% if session.lab_title %}
                      <span class="pill-tag">{{ session.lab_title }}</span>
                    {% endif %}
                  </div>
                  <button class="vision25-modal__close" type="button" data-dialog-close aria-label="{{ 'Close dialog'|t }}">
                    {{ 'Close'|t }} <span aria-hidden="true">✕</span>
                  </button>
                </div>
              </div>
            {% endfor %}
          </div>
        </section>
      {% endfor %}
    </div>
  </div>
</section>
