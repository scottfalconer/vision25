{% set boxes = [
  {'label': box_hero_label, 'modifier': 'vision25-system-overlay__box--hero'},
  {'label': box_header_label, 'modifier': 'vision25-system-overlay__box--header'},
  {'label': box_triangle_label, 'modifier': 'vision25-system-overlay__box--triangle'},
  {'label': box_bento_label, 'modifier': 'vision25-system-overlay__box--bento'},
  {'label': box_cta_label, 'modifier': 'vision25-system-overlay__box--cta'},
  {'label': box_timeline_label, 'modifier': 'vision25-system-overlay__box--timeline'},
] %}

<section{{ attributes.addClass('vision25-page-section', 'vision25-page-section--tight-top', 'safe-frame') }}>
  <div class="section-container vision25-stack--wide">
    <div class="vision25-toggle-group" data-toggle-group data-toggle-target="[data-toggle-item]">
      <button class="vision25-toggle-button is-active" type="button" data-toggle-value="visitor" aria-selected="true">{{ visitor_button_label }}</button>
      <button class="vision25-toggle-button" type="button" data-toggle-value="system" aria-selected="false">{{ system_button_label }}</button>
    </div>

    <section class="vision25-system-frame glass-card-elevated" data-scroll-reveal>
      <div class="vision25-system-canvas" data-toggle-item="visitor">
        <div class="vision25-system-grid">
          <div class="vision25-system-placeholder vision25-system-placeholder--hero">
            <h3 class="heading-section">{{ visitor_hero_label }}</h3>
          </div>
          <div class="vision25-system-placeholder vision25-system-placeholder--header">
            <p class="heading-card">{{ visitor_header_label }}</p>
          </div>
          <div class="vision25-system-placeholder vision25-system-placeholder--triangle">
            <p class="body-large">{{ visitor_triangle_label }}</p>
          </div>
          <div class="vision25-system-bento">
            <div class="vision25-system-placeholder vision25-system-placeholder--bento">
              <p>{{ visitor_bento_card_one_label }}</p>
            </div>
            <div class="vision25-system-placeholder vision25-system-placeholder--bento">
              <p>{{ visitor_bento_card_two_label }}</p>
            </div>
            <div class="vision25-system-placeholder vision25-system-placeholder--bento">
              <p>{{ visitor_bento_card_three_label }}</p>
            </div>
          </div>
          <div class="vision25-system-placeholder vision25-system-placeholder--cta">
            <p>{{ visitor_cta_label }}</p>
          </div>
          <div class="vision25-system-placeholder vision25-system-placeholder--timeline">
            <p>{{ visitor_timeline_label }}</p>
          </div>
        </div>
      </div>

      <div class="vision25-system-overlay is-hidden" data-toggle-item="system">
        {% for box in boxes %}
          <div class="vision25-system-overlay__box {{ box.modifier }}">
            <span class="vision25-system-overlay__label">{{ box.label }}</span>
          </div>
        {% endfor %}
      </div>
    </section>
  </div>
</section>
