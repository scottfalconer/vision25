<section{{ attributes.addClass('safe-frame', 'vision25-page-section', 'vision25-page-section--tight-top') }}>
  <div class="section-container vision25-stack--wide">
    <div class="vision25-toggle-group" data-toggle-group data-toggle-target="[data-toggle-item]">
      <button class="vision25-toggle-button is-active" type="button" data-toggle-value="past" aria-selected="true">{{ past_label }}</button>
      <button class="vision25-toggle-button" type="button" data-toggle-value="future" aria-selected="false">{{ future_label }}</button>
    </div>

    <div class="vision25-timeline" data-toggle-item="past">
      {% for milestone in past_milestones %}
        <article class="vision25-timeline__item" data-scroll-reveal>
          <span class="vision25-timeline__dot"></span>
          <div class="vision25-timeline__content">
            <p class="heading-card">{{ milestone.year }}</p>
            <p class="body-large">{{ milestone.title }}</p>
          </div>
          <div class="vision25-timeline__image glass-card-elevated"><img src="{{ milestone.image }}" alt="{{ milestone.title }}"></div>
        </article>
      {% endfor %}
    </div>

    <div class="vision25-timeline is-hidden" data-toggle-item="future">
      {% for milestone in future_milestones %}
        <article class="vision25-timeline__item" data-scroll-reveal>
          <span class="vision25-timeline__dot"></span>
          <div class="vision25-timeline__content">
            <p class="heading-card">{{ milestone.year }}</p>
            <p class="body-large">{{ milestone.title }}</p>
          </div>
          <div class="vision25-timeline__image glass-card-elevated"><img src="{{ milestone.image }}" alt="{{ milestone.title }}"></div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
