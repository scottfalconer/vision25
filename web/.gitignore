# Site-specific settings and files.
/sites/*/settings*.php
/sites/*/services*.yml
/sites/*/files
/sites/*/private
!/sites/default/settings.php
!/sites/default/services.yml

# Test site directories generated by automated testing.
/sites/simpletest

